{
  "name": "catworld",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "start:web": "next start",
    "start:worker": "tsx src/worker/index.ts",
    "worker": "tsx src/worker/index.ts",
    "typecheck": "tsc --noEmit",
    "check:encoding": "node scripts/check-encoding.mjs",
    "db:generate": "prisma generate",
    "migrate": "prisma migrate deploy",
    "db:migrate": "prisma migrate dev",
    "seed": "tsx prisma/seed.ts",
    "ci": "npm run check:encoding && npm run lint && npm run typecheck && npm test && npm run build",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.19.3",
    "csv-parse": "^6.1.0",
    "exceljs": "^4.4.0",
    "iconv-lite": "^0.7.0",
    "lucide-react": "^0.468.0",
    "mssql": "^12.5.5",
    "next": "^16.0.0",
    "next-auth": "^5.0.0-beta.31",
    "prisma": "6.19.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.20.6",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/mssql": "^9.1.8",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "daisyui": "^5.5.23",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.0.0",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "browserslist": "> 1%",
  "overrides": {
    "uuid": "^11.1.1",
    "postcss": "^8.5.10"
  }
